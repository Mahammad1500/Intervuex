VITE_API_URL=http://localhost:5000/api
VITE_APP_NAME=Intervuex

# UI-only public demo (Vercel only — no backend needed)
VITE_UI_DEMO_MODE=true

# OR full-stack demo (needs demo Railway + MongoDB intervuex_demo)
# VITE_API_URL=https://your-demo-api.railway.app/api
# VITE_SHOW_DEMO_LOGIN=true
# VITE_DEMO_VIEW_EMAILS=admin@intervuex.com,hr@intervuex.com

# Demo login buttons on /login: shown automatically in `npm run dev`.
# Production build (Vercel) hides them. Set false locally to hide:
# VITE_SHOW_DEMO_LOGIN=false
